#!/usr/bin/env python3
"""
record_generator.py
3D Printable Vinyl Record Generator from Audio Files
音声ファイルから3Dプリンター用レコードSTL生成ツール

Usage / 使い方:
  python record_generator.py --help
  python record_generator.py --audio input.wav --size 12 --rpm 33 --groove mono --sides 1
"""

